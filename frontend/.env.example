# Frontend Environment Variables
# Use /api for both development (proxied by Vite) and production (proxied by nginx)
# This avoids CORS issues as requests stay same-origin
VITE_API_URL=/api

# Optional app-shell display font override (expects a self-hosted WOFF2 URL).
# VITE_EXCALIDASH_UI_FONT_FAMILY=MyFont
# VITE_EXCALIDASH_UI_FONT_URL=/fonts/my-font.woff2
