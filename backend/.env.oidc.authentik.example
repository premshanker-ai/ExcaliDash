# Existing Authentik deployment example (no bundled Authentik required).
#
# Usage:
#   cd backend
#   cp .env.oidc.authentik.example .env
#   npm run oidc:doctor
#   npm run dev

NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:6767

AUTH_MODE=oidc_enforced

OIDC_PROVIDER_NAME=Authentik
# Issuer should be your provider URL:
#   https://<authentik-host>/application/o/<provider-slug>/
OIDC_ISSUER_URL=https://auth.example.com/application/o/excalidash/
OIDC_CLIENT_ID=excalidash

# Set only for confidential clients.
# OIDC_CLIENT_SECRET=change-me

OIDC_REDIRECT_URI=http://localhost:6767/api/auth/oidc/callback
OIDC_SCOPES=openid profile email

# Optional, depending on your Authentik mappings.
# OIDC_REQUIRE_EMAIL_VERIFIED=false
