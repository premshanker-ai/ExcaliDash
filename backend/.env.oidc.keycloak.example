# Existing Keycloak deployment example (no bundled Keycloak required).
#
# Usage:
#   cd backend
#   cp .env.oidc.keycloak.example .env
#   npm run oidc:doctor
#   npm run dev

NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:6767

AUTH_MODE=oidc_enforced

OIDC_PROVIDER_NAME=Keycloak
# Issuer should be your realm URL:
#   https://<keycloak-host>/realms/<realm>
OIDC_ISSUER_URL=https://sso.example.com/realms/excalidash
OIDC_CLIENT_ID=excalidash

# Set only for confidential clients.
# OIDC_CLIENT_SECRET=change-me

OIDC_REDIRECT_URI=http://localhost:6767/api/auth/oidc/callback
OIDC_SCOPES=openid profile email

# Optional:
# OIDC_REQUIRE_EMAIL_VERIFIED=true
